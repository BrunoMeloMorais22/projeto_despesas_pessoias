generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "debian-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Despesas {
  id        Int      @id @default(autoincrement())
  descricao String
  valor     Float
  categoria String
  data      DateTime
}
