generator client { 
  provider = "prisma-client-js" 
  binaryTargets = ["native", "debian-openssl-3.0.x"] 
  } 


datasource db { 
  provider = "postgresql" 
  url = env("DATABASE_URL") 
}

model usuario {
  id    Int     @id @default(autoincrement())
  nome  String
  email String  @unique
  senha String

  despesas despesa[]
}

model despesa {
  id        Int      @id @default(autoincrement())
  descricao String
  valor     Float
  categoria String
  data      DateTime

  userId    Int
  usuario   usuario @relation(fields: [userId], references: [id])
}