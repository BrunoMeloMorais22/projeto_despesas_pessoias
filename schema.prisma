
generator client{
    provider = "prisma-client-js"
    binaryTargets = ["native", "debian-openssl-3.0.x"]
}

model Despesas {
    id Int @id @default(autoincrement())
    descricao String
    valor Float
    categoria String
    data DateTime
}

datasource db {
    provider = "mysql"
    url = env("DATABASE_URL")
}